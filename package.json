{
  "name": "thepinkfront-game",
  "version": "1.0.0",
  "description": "Dykeathon Pink Front game",
  "homepage": "https://github.com/Shery-Blich/ThePinkFront#readme",
  "bugs": {
    "url": "https://github.com/Shery-Blich/ThePinkFront/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Shery-Blich/ThePinkFront.git"
  },
  "license": "ISC",
  "author": "",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "dev:admin": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend run dev",
    "install:all": "npm install && npm --prefix frontend install && npm --prefix backend install",
    "build:firebase": "node scripts/build-firebase.mjs",
    "deploy:hosting": "npm run build:firebase && firebase deploy --only hosting",
    "deploy:api": "node scripts/deploy-api.mjs",
    "deploy": "npm run deploy:api && npm run deploy:hosting"
  },
  "dependencies": {
    "phaser": "^3.88.2",
    "phaser3-rex-plugins": "^1.80.20"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "vite": "^6.3.5",
    "vue": "^3.5.39"
  }
}
