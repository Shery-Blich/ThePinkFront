# העתיקו ל-.env.firebase ומלאו ערכים לפני פריסה:
#   cp .env.firebase.example .env.firebase

# Firebase / Google Cloud
FIREBASE_PROJECT_ID=your-firebase-project-id
CLOUD_RUN_REGION=me-west1
CLOUD_RUN_SERVICE=thepinkfront-api

# הדומיין שלכם (אחרי חיבור ב-Firebase Hosting)
SITE_URL=https://your-domain.com

# Backend (Cloud Run)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/dykehaton
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=1h
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
ADMIN_WHITELIST=admin@example.com
CLIENT_ORIGIN=https://your-domain.com
COOKIE_SECURE=true
