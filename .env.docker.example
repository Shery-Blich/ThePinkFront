# העתיקו לקובץ .env בשורש הפרויקט לפני הרצה:
#   cp .env.docker.example .env

# פורט האתר (ברירת מחדל: 80)
WEB_PORT=80

# כתובת האתר הציבורית (ל-CORS)
CLIENT_ORIGIN=http://localhost

# MongoDB — ב-Docker מוגדר אוטומטית ב-docker-compose.yml
# MONGODB_URI=mongodb://mongodb:27017/dykehaton

JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=1h

GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
ADMIN_WHITELIST=admin@example.com

# לפריסה ב-HTTP בלי HTTPS (למשל localhost) — חובה לכניסת אדמין:
COOKIE_SECURE=false

# לפריסה עם HTTPS — הגדירו:
# CLIENT_ORIGIN=https://your-domain.com
# COOKIE_SECURE=true
